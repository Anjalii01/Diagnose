# Copy this file to .env and fill in real values before deploying.
# Never commit your actual .env file.

# A long, random, secret string used to sign login tokens.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=wcbOgry2SVFLX7T0lItMcN1W0SKw0XAEHKRjPgeTCXU

# How long a login session stays valid, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite by default. Swap for a Postgres/Supabase URL in production:
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
DATABASE_URL=sqlite:///./disease_prediction.db

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=diagnose-ap4o.vercel.app

# Rate limits (requests per time window) for sensitive endpoints.
PREDICT_RATE_LIMIT=20/minute
AUTH_RATE_LIMIT=10/minute


