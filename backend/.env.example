# Copy this file to .env and fill in real values before deploying.
# Never commit your actual .env file.

# A long, random, secret string used to sign login tokens.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-long-random-string

# How long a login session stays valid, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite by default. Swap for a Postgres/Supabase URL in production:
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
DATABASE_URL="postgresql://postgres.ofgdzwlowjhdlejurxby:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173

# Rate limits (requests per time window) for sensitive endpoints.
PREDICT_RATE_LIMIT=20/minute
AUTH_RATE_LIMIT=10/minute

# Optional: for LLM-based free-text symptom matching (/symptoms/match).
# Get a key from https://console.anthropic.com/settings/keys
# If left blank, the app automatically falls back to the offline
# synonym+fuzzy matcher in symptom_matcher.py -- no key is required to run.
ANTHROPIC_API_KEY=

# Optional alternative to the above: Google Gemini has a genuinely free API
# tier (rate-limited). Get a key from https://aistudio.google.com/apikey
# If GEMINI_API_KEY is set, it's tried BEFORE Claude (since it's free).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
